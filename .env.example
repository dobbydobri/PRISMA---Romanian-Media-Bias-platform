# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=media_bias_db

DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5433/media_bias_db
