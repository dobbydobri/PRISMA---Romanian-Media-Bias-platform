QUERY_SERVER_URL_DOCKER=http://query-embedder:8081

# ASP.NET API
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5170

# Angular dev server target
API_BASE_URL=http://localhost:5170